# IPEC — Espace étudiant
# Bloque tout accès direct aux fichiers internes.

<FilesMatch "^_">
    Require all denied
</FilesMatch>

# Bloque les fichiers de config / migration
<FilesMatch "\.(sql|md|env|json|lock)$">
    Require all denied
</FilesMatch>

# Pas d'index automatique — protégé pour éviter un 500 si Options est interdit par l'hébergeur
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>
DirectoryIndex index.php
