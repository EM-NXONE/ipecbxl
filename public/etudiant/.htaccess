# IPEC — Espace étudiant
# Bloque tout accès direct aux fichiers internes.

<FilesMatch "^_">
    Require all denied
</FilesMatch>

<FilesMatch "^(db_config\.php|mailer\.php)$">
    Require all denied
</FilesMatch>

# Bloque les fichiers de config / migration
<FilesMatch "\.(sql|md|env|json|lock)$">
    Require all denied
</FilesMatch>

DirectoryIndex index.php
