RewriteEngine On

# CORS preflight (OPTIONS) bypass de l'auth Apache éventuelle
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=204,L]

# Bloquer l'accès direct aux fichiers _* (helpers internes)
<FilesMatch "^_">
  Require all denied
</FilesMatch>

# Bloquer .sql / .md
<FilesMatch "\.(sql|md)$">
  Require all denied
</FilesMatch>
